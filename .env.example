OPENAI_API_KEY=your_openai_api_key_here

ROBOT_NAME=Ameego
WAKE_WORD_NAME=Hey Nomi
WAKEWORD_MODEL_PATH=
WAKEWORD_BUILTIN_MODEL=hey_jarvis
WAKEWORD_THRESHOLD=0.55

OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

AUDIO_INPUT_DEVICE=plughw:2,0
AUDIO_OUTPUT_DEVICE=plughw:1,0
AUDIO_SAMPLE_RATE=16000
AUDIO_OUTPUT_SAMPLE_RATE=24000
AUDIO_CHANNELS=1

LISTEN_MAX_SECONDS=12.0
LISTEN_MIN_SECONDS=1.0
SILENCE_SECONDS=1.1
SILENCE_THRESHOLD=0.012
PRE_ROLL_SECONDS=0.35
PLAYBACK_COOLDOWN_SECONDS=1.0
IDLE_SLEEP_TIMEOUT_SECONDS=180

EYES_ENABLED=true
EYES_FULLSCREEN=true
EYES_WIDTH=800
EYES_HEIGHT=480
EYES_FPS=30

LOG_LEVEL=INFO
